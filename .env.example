# IRoom Configuration
# Copy this file to .env and update values

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Database
DATABASE_PATH=iroom.db

# JWT
JWT_SECRET=change-me-in-production-use-random-string
JWT_ACCESS_EXPIRY=15
JWT_REFRESH_EXPIRY=10080

# Upload
UPLOAD_MAX_SIZE=52428800
UPLOAD_DIR=uploads

# External API
EXTERNAL_API_KEY=change-me-external-api-key
