general: {
    configs_folder = "/etc/janus"
    plugins_folder = "/opt/janus/lib/janus/plugins"
    transports_folder = "/opt/janus/lib/janus/transports"
    log_to_stdout = true
    debug_level = 4
    admin_secret = "janusadmin"
}

nat: {
    nice_debug = false
    full_trickle = true
    ice_lite = false
    stun_server = "stun.l.google.com"
    stun_port = 19302
}

media: {
    rtp_port_range = "20000-60000"
}
